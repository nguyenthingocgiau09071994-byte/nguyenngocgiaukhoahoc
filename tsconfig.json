{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src", "src/**/*.ts"],
  "exclude": ["node_modules", "dist", "*.js"]
}
