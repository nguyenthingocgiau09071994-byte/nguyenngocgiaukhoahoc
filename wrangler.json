{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "masterclass-api",
  "main": "src/index.ts",
  "compatibility_date": "2024-01-01",
  "assets": {
    "browser_bindings": {}
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "masterclass-db",
      "database_id": "YOUR_DATABASE_ID"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "YOUR_KV_ID"
    }
  ],
  "vars": {
    "ADMIN_EMAILS": "admin@masterclass.vn,nguyenngocgiau.com@gmail.com,nguyenngocgiau@gmail.com,admin@nguyenngocgiau.com,giaunne@gmail.com,giau@nguyenngocgiau.com",
    "JWT_SECRET": "YOUR_JWT_SECRET_MIN_32_CHARS_LONG"
  },
  "secret_names": [
    "JWT_SECRET",
    "CLOUDFLARE_ACCOUNT_ID"
  ],
  "routes": [
    {
      "pattern": "api.nguyenngocgiau.com",
      "zone_name": "nguyenngocgiau.com"
    }
  ]
}
